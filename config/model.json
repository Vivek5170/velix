{
	"active_adapter": "llama.cpp",
	"adapters": {
		"llama.cpp": {
			"api_style": "openai-chat-completions",
			"base_url": "http://127.0.0.1:8080/v1",
			"model": "local-model",
			"api_key_env": null,
			"stop_tokens": ["END_EXEC"]
		},
		"ollama": {
			"enabled": false,
			"api_style": "openai-chat-completions",
			"base_url": "http://127.0.0.1:11434/v1",
			"model": "llama3",
			"api_key_env": null,
			"stop_tokens": ["END_EXEC"]
		}
	},
	"request_timeout_ms": 60000,
	"default_sampling_params": {
		"temp": 0.7,
		"top_p": 0.9,
		"max_tokens": 512
	}
}
