{
  "name": "web_search",
  "type": "tool",
  "description": "Web search tool. Use when you need to get latest data or verify global facts or know about something new/related..",
  "runtime": "python",
  "entry": "main.py",
  "workdir": ".",
  "prepare": [],
  "parameters": {
    "type": "object",
    "properties": {
      "query": {
        "type": "string",
        "description": "Search query text"
      },
      "max_results": {
        "type": "number",
        "description": "Maximum number of results per source (1-8)"
      },
      "timeout_sec": {
        "type": "number",
        "description": "Per-provider request timeout in seconds (1-20)"
      },
      "mode": {
        "type": "string",
        "description": "Pipeline mode: sequential or parallel"
      },
      "sources": {
        "type": "array",
        "items": { "type": "string" },
        "description": "Optional provider subset from: brave, tavily, firecrawl, wikipedia, arxiv, duckduckgo"
      },
      "allow_firecrawl_scrape": {
        "type": "boolean",
        "description": "Allow Firecrawl markdown scraping mode"
      }
    },
    "required": ["query"]
  },
  "run": {
    "command": "uv",
    "args": ["run", "main.py"]
  }
}
